{
  "name": "lark-kiro-bridge",
  "version": "0.9.2",
  "description": "LWA — Lark Local Agent Workbench gateway: Feishu/CLI entry, multi-runtime routing (Kiro/Cursor/Gemini/OpenAI). CLI: `lwa` (aliases: lwa-bridge, lark-kiro-bridge).",
  "type": "module",
  "bin": {
    "lwa": "bin/lwa.mjs",
    "lwa-bridge": "bin/lwa.mjs",
    "lark-kiro-bridge": "bin/lwa.mjs"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/dashboard-ui/**/*",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "pnpm build:ui && tsup && node scripts/copy-dashboard-ui.mjs",
    "build:ui": "pnpm --dir dashboard-ui build",
    "typecheck": "tsc --noEmit && pnpm --dir dashboard-ui typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src dashboard-ui/src",
    "lint:fix": "biome check src dashboard-ui/src --write",
    "format": "biome format src dashboard-ui/src --write",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "start": "node bin/lwa.mjs serve",
    "prepublishOnly": "npx tsc --noEmit && npx biome check src && npx vitest run && pnpm build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.65.0",
    "@slack/bolt": "^4.7.3",
    "@slack/types": "^2.22.0",
    "@slack/web-api": "^7.19.0",
    "commander": "^14.0.3",
    "croner": "^9.0.0",
    "execa": "^9.5.2",
    "p-queue": "^8.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^11.3.0",
    "proper-lockfile": "^4.1.2",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.10.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/qrcode-terminal": "^0.12.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "tsup": "^8.3.5",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.18.0",
  "keywords": [
    "feishu",
    "lark",
    "lwa",
    "lark-local-agent-workbench",
    "bridge",
    "kiro",
    "kiro-cli",
    "cursor",
    "multi-cli",
    "agent-routing",
    "bot",
    "ai-coding-agent"
  ],
  "author": "walterwang0x01",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walterwang0x01/lwa-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/walterwang0x01/lwa-bridge/issues"
  },
  "homepage": "https://github.com/walterwang0x01/lwa-bridge#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs"
    ]
  }
}
