{
  "name": "lark-kiro-bridge",
  "version": "0.1.0",
  "description": "Bridge Feishu/Lark messenger with local Kiro CLI — streaming cards, per-chat sessions, named workspaces",
  "type": "module",
  "bin": {
    "lark-kiro-bridge": "./bin/lark-kiro-bridge.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node bin/lark-kiro-bridge.mjs run",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.65.0",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "p-queue": "^8.0.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "proper-lockfile": "^4.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/proper-lockfile": "^4.1.4",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "feishu",
    "lark",
    "kiro",
    "kiro-cli",
    "bridge",
    "bot",
    "ai-coding-agent"
  ],
  "license": "MIT"
}
